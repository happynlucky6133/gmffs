generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-Company Core ───────────────────────────────

enum Role {
  platform_admin
  company_admin
  ops
  sales
  warehouse
  production
  finance
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       CompanyUser[]
  // Future: products, orders, inventory, etc.

  @@map("companies")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies CompanyUser[]

  @@map("users")
}

model CompanyUser {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      Role
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@map("company_users")
}
