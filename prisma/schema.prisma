generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-Company Core ───────────────────────────────

enum Role {
  platform_admin
  company_admin
  ops
  sales
  warehouse
  production
  finance
}

enum CompanyStatus {
  active
  suspended
  archived
}

enum OrderStatus {
  draft
  confirmed
  cancelled
}

enum PaymentStatus {
  unpaid
  awaiting_confirmation
  paid
  failed
  refund_required
  refunded
}

enum AllocationStatus {
  not_required
  pending
  allocated
  failed
  released
}

enum FulfillmentStatus {
  pending
  production_required
  ready_to_pack
  packed
  ready_for_pickup
  handed_over
  completed
  cancelled
}

enum DeliveryStatus {
  not_required
  pending_quote
  quoted
  booked
  picked_up
  delivered
  failed
  cancelled
}

enum PaymentMethodType {
  touch_n_go
  bank_transfer
  cash_on_delivery
  payment_link
}

enum PaymentEventType {
  created
  proof_submitted
  confirmed
  failed
  refund_required
  refunded
}

enum InventoryMovementType {
  adjustment
  reservation
  release
  consume
  production_output
}

enum AllocationAttemptStatus {
  success
  failed
}

enum AllocationLineStatus {
  reserved
  released
  consumed
}

enum ProductionTaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum DeliveryProviderType {
  mock
  lalamove
  manual
}

enum DeliveryEventType {
  quoted
  booked
  picked_up
  delivered
  failed
  cancelled
  webhook_received
}

model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  domain    String?
  status    CompanyStatus @default(active)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  users                 CompanyUser[]
  products              Product[]
  skus                  Sku[]
  customers             Customer[]
  orders                Order[]
  paymentMethods        PaymentMethod[]
  payments              Payment[]
  paymentEvents         PaymentEvent[]
  inventoryLocations    InventoryLocation[]
  inventoryBalances     InventoryBalance[]
  inventoryReservations InventoryReservation[]
  inventoryMovements    InventoryMovement[]
  allocationAttempts    AllocationAttempt[]
  allocationLines       AllocationLine[]
  productionTasks       ProductionTask[]
  deliveries            Delivery[]
  deliveryEvents        DeliveryEvent[]
  serviceAreas          ServiceArea[]
  auditLogs             AuditLog[]

  @@map("companies")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies CompanyUser[]
  auditLogs AuditLog[]

  @@map("users")
}

model CompanyUser {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      Role
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId, role])
  @@map("company_users")
}

// ─── Catalog And Customers ────────────────────────────

model Product {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  imageUrl    String?
  displayOrder Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skus    Sku[]

  @@index([companyId, isActive])
  @@map("products")
}

model Sku {
  id        String   @id @default(cuid())
  companyId String
  productId String
  code      String
  name      String
  unit      String
  price     Decimal  @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product               Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems            OrderItem[]
  inventoryBalances     InventoryBalance[]
  inventoryReservations InventoryReservation[]
  inventoryMovements    InventoryMovement[]
  allocationLines       AllocationLine[]
  productionTasks       ProductionTask[]

  @@unique([companyId, code])
  @@index([companyId, productId])
  @@index([companyId, isActive])
  @@map("skus")
}

model Customer {
  id        String   @id @default(cuid())
  companyId String
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@index([companyId, phone])
  @@index([companyId, email])
  @@map("customers")
}

// ─── Orders And Payments ──────────────────────────────

model Order {
  id                String            @id @default(cuid())
  companyId         String
  customerId        String
  orderNumber       String
  sourceChannel     String
  deliveryAddress   String
  requestedTimeSlot String?
  subtotal          Decimal           @default(0) @db.Decimal(12, 2)
  deliveryFee       Decimal           @default(0) @db.Decimal(12, 2)
  total             Decimal           @default(0) @db.Decimal(12, 2)
  orderStatus       OrderStatus       @default(draft)
  paymentStatus     PaymentStatus     @default(unpaid)
  allocationStatus  AllocationStatus  @default(pending)
  fulfillmentStatus FulfillmentStatus @default(pending)
  deliveryStatus    DeliveryStatus    @default(not_required)
  notes             String?
  confirmedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer              Customer               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items                 OrderItem[]
  payments              Payment[]
  inventoryReservations InventoryReservation[]
  inventoryMovements    InventoryMovement[]
  allocationAttempts    AllocationAttempt[]
  productionTasks       ProductionTask[]
  deliveries            Delivery[]

  @@unique([companyId, orderNumber])
  @@index([companyId, customerId])
  @@index([companyId, orderStatus, paymentStatus])
  @@index([companyId, allocationStatus])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  skuId     String
  quantity  Decimal  @db.Decimal(12, 3)
  unitPrice Decimal  @db.Decimal(12, 2)
  lineTotal Decimal  @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order                 Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku                   Sku                    @relation(fields: [skuId], references: [id], onDelete: Restrict)
  inventoryReservations InventoryReservation[]
  allocationLines       AllocationLine[]
  productionTasks       ProductionTask[]

  @@index([orderId])
  @@index([skuId])
  @@map("order_items")
}

model PaymentMethod {
  id        String            @id @default(cuid())
  companyId String
  type      PaymentMethodType
  name      String
  enabled   Boolean           @default(false)
  settings  Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@unique([companyId, type])
  @@index([companyId, enabled])
  @@map("payment_methods")
}

model Payment {
  id              String        @id @default(cuid())
  companyId       String
  orderId         String
  paymentMethodId String
  amount          Decimal       @db.Decimal(12, 2)
  status          PaymentStatus @default(awaiting_confirmation)
  proofUrl        String?
  referenceNumber String?
  confirmedAt     DateTime?
  failedAt        DateTime?
  refundedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod  @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  events        PaymentEvent[]

  @@index([companyId, orderId])
  @@index([companyId, status])
  @@map("payments")
}

model PaymentEvent {
  id        String           @id @default(cuid())
  companyId String
  paymentId String
  type      PaymentEventType
  notes     String?
  metadata  Json?
  createdAt DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([companyId, paymentId])
  @@index([companyId, type])
  @@map("payment_events")
}

// ─── Inventory And Allocation ─────────────────────────

model InventoryLocation {
  id        String   @id @default(cuid())
  companyId String
  name      String
  code      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  balances           InventoryBalance[]
  reservations       InventoryReservation[]
  movements          InventoryMovement[]
  allocationAttempts AllocationAttempt[]
  allocationLines    AllocationLine[]
  productionTasks    ProductionTask[]
  deliveries         Delivery[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("inventory_locations")
}

model InventoryBalance {
  id         String   @id @default(cuid())
  companyId  String
  locationId String
  skuId      String
  onHand     Decimal  @default(0) @db.Decimal(12, 3)
  reserved   Decimal  @default(0) @db.Decimal(12, 3)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sku      Sku               @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@unique([companyId, locationId, skuId])
  @@index([companyId, skuId])
  @@map("inventory_balances")
}

model InventoryReservation {
  id          String               @id @default(cuid())
  companyId   String
  orderId     String
  orderItemId String
  locationId  String
  skuId       String
  quantity    Decimal              @db.Decimal(12, 3)
  status      AllocationLineStatus @default(reserved)
  createdAt   DateTime             @default(now())
  releasedAt  DateTime?
  consumedAt  DateTime?

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem         @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  location  InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  sku       Sku               @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@index([companyId, orderId])
  @@index([companyId, locationId, skuId])
  @@index([companyId, status])
  @@map("inventory_reservations")
}

model InventoryMovement {
  id          String                @id @default(cuid())
  companyId   String
  locationId  String
  skuId       String
  orderId     String?
  type        InventoryMovementType
  quantity    Decimal               @db.Decimal(12, 3)
  reason      String?
  referenceId String?
  createdAt   DateTime              @default(now())

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  sku      Sku               @relation(fields: [skuId], references: [id], onDelete: Restrict)
  order    Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([companyId, locationId, skuId])
  @@index([companyId, orderId])
  @@index([companyId, type])
  @@map("inventory_movements")
}

model AllocationAttempt {
  id         String                  @id @default(cuid())
  companyId  String
  orderId    String
  locationId String?
  status     AllocationAttemptStatus
  reason     String?
  score      Int?
  createdAt  DateTime                @default(now())

  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order    Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  location InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  lines    AllocationLine[]

  @@index([companyId, orderId])
  @@index([companyId, status])
  @@map("allocation_attempts")
}

model AllocationLine {
  id                  String               @id @default(cuid())
  companyId           String
  allocationAttemptId String
  orderItemId         String
  locationId          String
  skuId               String
  quantity            Decimal              @db.Decimal(12, 3)
  status              AllocationLineStatus @default(reserved)
  createdAt           DateTime             @default(now())

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  allocationAttempt AllocationAttempt @relation(fields: [allocationAttemptId], references: [id], onDelete: Cascade)
  orderItem         OrderItem         @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  location          InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  sku               Sku               @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@index([companyId, allocationAttemptId])
  @@index([companyId, locationId, skuId])
  @@map("allocation_lines")
}

// ─── Production, Delivery, Service Areas, Audit ───────

model ProductionTask {
  id          String               @id @default(cuid())
  companyId   String
  orderId     String?
  orderItemId String?
  locationId  String
  skuId       String
  quantity    Decimal              @db.Decimal(12, 3)
  status      ProductionTaskStatus @default(pending)
  notes       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order     Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItem OrderItem?        @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  location  InventoryLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  sku       Sku               @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@index([companyId, status])
  @@index([companyId, orderId])
  @@index([companyId, locationId])
  @@map("production_tasks")
}

model Delivery {
  id             String               @id @default(cuid())
  companyId      String
  orderId        String
  locationId     String?
  provider       DeliveryProviderType @default(mock)
  status         DeliveryStatus       @default(pending_quote)
  quoteAmount    Decimal?             @db.Decimal(12, 2)
  trackingNumber String?
  providerRef    String?
  pickupAddress  String?
  dropoffAddress String
  scheduledAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order    Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  location InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  events   DeliveryEvent[]

  @@index([companyId, orderId])
  @@index([companyId, status])
  @@index([companyId, provider])
  @@map("deliveries")
}

model DeliveryEvent {
  id         String            @id @default(cuid())
  companyId  String
  deliveryId String
  type       DeliveryEventType
  notes      String?
  payload    Json?
  createdAt  DateTime          @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([companyId, deliveryId])
  @@index([companyId, type])
  @@map("delivery_events")
}

model ServiceArea {
  id        String   @id @default(cuid())
  companyId String
  name      String
  code      String
  polygon   Json?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@index([companyId, enabled])
  @@map("service_areas")
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, entity, entityId])
  @@index([companyId, action])
  @@index([companyId, userId])
  @@map("audit_logs")
}
